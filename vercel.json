{
  "name": "job-trackers",
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "public": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "functions": {
    "api/:path*.ts": {
      "memory": 3008,
      "maxDuration": 30
    }
  }
}
