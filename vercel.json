{
  "name": "job-trackers",
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "public": true,
  "env": {
    "DATABASE_URL": "@database_url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Forwarded-For",
          "value": "${IP}"
        },
        {
          "key": "X-Forwarded-Proto",
          "value": "${PROTOCOL}"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "memory": 3008,
      "maxDuration": 30
    }
  }
}
